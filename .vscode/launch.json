{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "J-Link Debug",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/Debug/VS-CODE-F103.elf",
            "servertype": "jlink",
            "device": "STM32F103RB",
            "interface": "swd",
            "svdFile": "${workspaceFolder}/.vscode/STM32F103.svd",
            "runToEntryPoint": "main"
        }
    ]
}
